        "when": "viewItem == table"
      },
      {
        "command": "database.modifyTable",
        "group": "data@6",
        "when": "viewItem == table"
      },
      {
        "command": "database.renameObject",
        "group": "change@1"
      },
      {
        "command": "database.dropObject",
        "group": "change@99"
      }
    ],
    "database.sqlScripts": [
      {
        "command": "database.showObjectDdl",
