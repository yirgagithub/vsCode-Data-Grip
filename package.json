{
  "name": "vscode-data-grip",
  "displayName": "Data Grip",
  "description": "A VS Code database client for PostgreSQL, Redshift, and MySQL.",
  "version": "0.0.6",
  "publisher": "vs-code-database-client",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yirgagithub/vsCode-Data-Grip.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:databaseExplorer",
    "onView:databaseQueryMap",
    "onView:sqlResults",
    "onLanguage:sql",
    "onCommand:database.addConnection",
    "onCommand:database.editConnection",
    "onCommand:database.deleteConnection",
    "onCommand:database.connect",
    "onCommand:database.disconnect",
    "onCommand:database.testConnection",
    "onCommand:database.openSqlConsole",
    "onCommand:database.openQueryFile",
    "onCommand:database.setSqlFileConnection",
    "onCommand:database.showSqlMetadataStatus",
    "onCommand:database.executeCurrentQuery",
    "onCommand:database.executeSelection",
    "onCommand:database.executeFile",
    "onCommand:database.cancelCurrentQuery",
    "onCommand:database.executeStatementRange",
    "onCommand:database.showResults",
    "onCommand:database.findPastQuery",
    "onCommand:database.backfillQueryMemorySummaries",
    "onCommand:database.aiFixSql",
    "onCommand:database.aiExplainSql",
    "onCommand:database.analyzeTablePerformance",
    "onCommand:database.visualExplainSql",
    "onCommand:database.visualExplainAnalyzeSql",
    "onCommand:database.profileTableData",
    "onCommand:database.generateTableMaintenanceSql",
    "onCommand:database.compareSchemas",
    "onCommand:database.showErDiagram",
    "onCommand:database.insertQuerySnippet",
    "onCommand:database.goToDatabaseObject",
    "onCommand:database.importTableData",
    "onCommand:database.copyTableToConnection",
    "onCommand:database.sessionMonitor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "database.addConnection",
        "title": "Add Database Connection",
        "category": "Database",
        "icon": "$(add)"
      },
      {
        "command": "database.editConnection",
        "title": "Edit Connection",
        "category": "Database"
      },
      {
        "command": "database.deleteConnection",
        "title": "Delete Connection",
        "category": "Database"
      },
      {
        "command": "database.testConnection",
        "title": "Test Database Connection",
        "category": "Database"
      },
      {
        "command": "database.connect",
        "title": "Connect",
        "category": "Database"
      },
      {
        "command": "database.disconnect",
        "title": "Disconnect",
        "category": "Database"
      },
      {
        "command": "database.showResults",
        "title": "Show SQL Results",
        "category": "Database"
      },
      {
        "command": "database.executeFile",
        "title": "Execute File / Selection",
        "category": "Database",
        "icon": {
          "dark": "media/run-file-dark.svg",
          "light": "media/run-file-light.svg"
        }
      },
      {
        "command": "database.cancelCurrentQuery",
        "title": "Cancel Query",
        "category": "Database",
        "icon": "$(debug-stop)",
        "enablement": "database.queryRunning"
      },
      {
        "command": "database.openSqlConsole",
        "title": "Add Query Console",
        "category": "Database",
        "icon": "$(new-file)"
      },
      {
        "command": "database.openQueryFile",
        "title": "Add Query File",
        "category": "Database"
      },
      {
        "command": "database.setSqlFileConnection",
        "title": "Set SQL File Connection",
        "category": "Database",
        "icon": "$(database)"
      },
      {
        "command": "database.showSqlMetadataStatus",
        "title": "Show SQL Metadata Status",
        "category": "Database"
      },
      {
        "command": "database.focusResults",
        "title": "Focus SQL Results",
        "category": "Database"
      },
      {
        "command": "database.focusExplorer",
        "title": "Focus Database Explorer",
        "category": "Database"
      },
      {
        "command": "database.showQueryHistory",
        "title": "Show Query History",
        "category": "Database"
      },
      {
        "command": "database.findPastQuery",
        "title": "Find Past Query...",
        "category": "Database",
        "icon": "$(search)"
      },
      {
        "command": "database.backfillQueryMemorySummaries",
        "title": "Backfill Query Memory Summaries",
        "category": "Database"
      },
      {
        "command": "database.aiFixSql",
        "title": "AI: Fix SQL",
        "category": "Database",
        "icon": "$(sparkle)"
      },
      {
        "command": "database.aiExplainSql",
        "title": "AI: Explain SQL",
        "category": "Database",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "database.visualExplainSql",
        "title": "Visual Explain SQL",
        "category": "Database",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "database.visualExplainAnalyzeSql",
        "title": "Visual Explain ANALYZE SQL",
        "category": "Database",
        "icon": "$(debug-alt)"
      },
      {
        "command": "database.analyzeTablePerformance",
        "title": "AI: Analyze Table Performance",
        "category": "Database",
        "icon": "$(graph-line)"
      },
      {
        "command": "database.profileTableData",
        "title": "Profile Table Data",
        "category": "Database",
        "icon": "$(pulse)"
      },
      {
        "command": "database.generateTableMaintenanceSql",
        "title": "Generate Maintenance SQL",
        "category": "Database",
        "icon": "$(warning)"
      },
      {
        "command": "database.compareSchemas",
        "title": "Compare Schemas...",
        "category": "Database",
        "icon": "$(diff)"
      },
      {
        "command": "database.showErDiagram",
        "title": "Show ER Diagram",
        "category": "Database",
        "icon": "$(graph)"
      },
      {
        "command": "database.insertQuerySnippet",
        "title": "Insert Query Snippet...",
        "category": "Database",
        "icon": "$(snippet)"
      },
      {
        "command": "database.goToDatabaseObject",
        "title": "Go to Database Object...",
        "category": "Database",
        "icon": "$(symbol-key)"
      },
      {
        "command": "database.importTableData",
        "title": "Import Table Data...",
        "category": "Database",
        "icon": "$(folder-opened)"
      },
      {
        "command": "database.copyTableToConnection",
        "title": "Copy Table to Connection...",
        "category": "Database",
        "icon": "$(copy)"
      },
      {
        "command": "database.sessionMonitor",
        "title": "Session Monitor",
        "category": "Database",
        "icon": "$(pulse)"
      },
      {
        "command": "database.openTableData",
        "title": "Open Table",
        "category": "Database"
      },
      {
        "command": "database.newObject",
        "title": "New...",
        "category": "Database",
        "icon": "$(add)"
      },
      {
        "command": "database.newTable",
        "title": "Generate CREATE TABLE",
        "category": "Database"
      },
      {
        "command": "database.newView",
        "title": "Generate CREATE VIEW",
        "category": "Database"
      },
      {
        "command": "database.newMaterializedView",
        "title": "Generate CREATE MATERIALIZED VIEW",
        "category": "Database"
      },
      {
        "command": "database.newColumn",
        "title": "Generate ADD COLUMN",
        "category": "Database"
      },
      {
        "command": "database.newIndex",
        "title": "Generate CREATE INDEX",
        "category": "Database"
      },
      {
        "command": "database.newUniqueKey",
        "title": "Generate UNIQUE KEY",
        "category": "Database"
      },
      {
        "command": "database.newForeignKey",
        "title": "Generate FOREIGN KEY",
        "category": "Database"
      },
      {
        "command": "database.newCheck",
        "title": "Generate CHECK",
        "category": "Database"
      },
      {
        "command": "database.newSchema",
        "title": "Generate CREATE SCHEMA",
        "category": "Database"
      },
      {
        "command": "database.newSequence",
        "title": "Generate CREATE SEQUENCE",
        "category": "Database"
      },
      {
        "command": "database.modifyTable",
        "title": "Generate ALTER TABLE",
        "category": "Database"
      },
      {
        "command": "database.renameObject",
        "title": "Generate RENAME",
        "category": "Database"
      },
      {
        "command": "database.dropObject",
        "title": "Generate DROP",
        "category": "Database"
      },
      {
        "command": "database.copyName",
        "title": "Copy Name",
        "category": "Database"
      },
      {
        "command": "database.copyQualifiedName",
        "title": "Copy Qualified Name",
        "category": "Database"
      },
      {
        "command": "database.showObjectDdl",
        "title": "Generate DDL",
        "category": "Database"
      },
      {
        "command": "database.generateSelect",
        "title": "Generate SELECT",
        "category": "Database"
      },
      {
        "command": "database.generateInsert",
        "title": "Generate INSERT",
        "category": "Database"
      },
      {
        "command": "database.generateUpdate",
        "title": "Generate UPDATE",
        "category": "Database"
      },
      {
        "command": "database.generateDelete",
        "title": "Generate DELETE",
        "category": "Database"
      },
      {
        "command": "database.quickDocumentation",
        "title": "Quick Documentation",
        "category": "Database"
      },
      {
        "command": "database.refreshExplorer",
        "title": "Refresh Database Explorer",
        "category": "Database",
        "icon": "$(refresh)"
      }
    ],
    "submenus": [
      {
        "id": "database.new",
        "label": "New"
      },
      {
        "id": "database.copyPaste",
        "label": "Copy/Paste"
      },
      {
        "id": "database.sqlScripts",
        "label": "SQL Scripts"
      },
      {
        "id": "database.objectActions",
        "label": "Object Actions"
      },
      {
        "id": "database.tools",
        "label": "Tools"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "database",
          "title": "Database",
          "icon": "media/database.svg"
        }
      ],
      "panel": [
        {
          "id": "databasePanel",
          "title": "Database",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "database": [
        {
          "id": "databaseExplorer",
          "name": "Database"
        },
        {
          "id": "databaseQueryMap",
          "name": "Query Sessions",
          "type": "webview"
        }
      ],
      "databasePanel": [
        {
          "id": "sqlResults",
          "name": "Database",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "database.findPastQuery",
          "when": "view == databaseExplorer",
          "group": "navigation@0"
        },
        {
          "command": "database.openSqlConsole",
          "when": "view == databaseExplorer",
          "group": "navigation@1"
        },
        {
          "command": "database.addConnection",
          "when": "view == databaseExplorer",
          "group": "navigation@2"
        },
        {
          "command": "database.refreshExplorer",
          "when": "view == databaseExplorer",
          "group": "navigation@3"
        },
        {
          "command": "database.findPastQuery",
          "when": "view == databaseQueryMap",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "submenu": "database.new",
          "when": "view == databaseExplorer && (viewItem == connection || viewItem == catalog || viewItem == schema || viewItem == tables || viewItem == views || viewItem == table)",
          "group": "navigation@1"
        },
        {
          "command": "database.modifyTable",
          "when": "view == databaseExplorer && viewItem == table",
          "group": "navigation@2"
        },
        {
          "submenu": "database.copyPaste",
          "when": "view == databaseExplorer",
          "group": "navigation@3"
        },
        {
          "command": "database.refreshExplorer",
          "when": "view == databaseExplorer",
          "group": "navigation@5"
        },
        {
          "command": "database.renameObject",
          "when": "view == databaseExplorer && (viewItem == schema || viewItem == table || viewItem == view || viewItem == column)",
          "group": "modify@1"
        },
        {
          "command": "database.quickDocumentation",
          "when": "view == databaseExplorer && (viewItem == schema || viewItem == table || viewItem == view || viewItem == column || viewItem == function || viewItem == procedure || viewItem == trigger)",
          "group": "inspect@1"
        },
        {
          "command": "database.sessionMonitor",
          "when": "view == databaseExplorer && (viewItem == connection || viewItem == catalog)",
          "group": "inspect@4"
        },
        {
          "submenu": "database.sqlScripts",
          "when": "view == databaseExplorer && (viewItem == table || viewItem == view)",
          "group": "scripts@1"
        },
        {
          "submenu": "database.objectActions",
          "when": "view == databaseExplorer && (viewItem == table || viewItem == view || viewItem == schema || viewItem == column)",
          "group": "actions@1"
        },
        {
          "submenu": "database.tools",
          "when": "view == databaseExplorer && (viewItem == connection || viewItem == catalog || viewItem == schema || viewItem == table || viewItem == view || viewItem == function || viewItem == procedure || viewItem == trigger)",
          "group": "tools@1"
        },
        {
          "command": "database.connect",
          "when": "view == databaseExplorer && viewItem == connection",
          "group": "connection@1"
        },
        {
          "command": "database.disconnect",
          "when": "view == databaseExplorer && viewItem == connection",
          "group": "connection@2"
        },
        {
          "command": "database.testConnection",
          "when": "view == databaseExplorer && viewItem == connection",
          "group": "connection@3"
        },
        {
          "command": "database.editConnection",
          "when": "view == databaseExplorer && viewItem == connection",
          "group": "connection@4"
        },
        {
          "command": "database.deleteConnection",
          "when": "view == databaseExplorer && viewItem == connection",
          "group": "connection@5"
        },
        {
          "command": "database.compareSchemas",
          "when": "view == databaseExplorer && (viewItem == connection || viewItem == catalog || viewItem == schema)",
          "group": "inspect@5"
        },
        {
          "command": "database.showErDiagram",
          "when": "view == databaseExplorer && (viewItem == connection || viewItem == catalog || viewItem == schema)",
          "group": "inspect@6"
        },
        {
          "command": "database.dropObject",
          "when": "view == databaseExplorer && (viewItem == schema || viewItem == table || viewItem == view || viewItem == column)",
          "group": "danger@99"
        }
      ],
      "database.new": [
        {
          "command": "database.openSqlConsole",
          "group": "query@0"
        },
        {
          "command": "database.openQueryFile",
          "group": "query@1"
        },
        {
          "command": "database.newColumn",
          "when": "viewItem == table || viewItem == column",
          "group": "constraint@1"
        },
        {
          "command": "database.newUniqueKey",
          "when": "viewItem == table || viewItem == column",
          "group": "constraint@2"
        },
        {
          "command": "database.newForeignKey",
          "when": "viewItem == table || viewItem == column",
          "group": "constraint@3"
        },
        {
          "command": "database.newIndex",
          "when": "viewItem == table || viewItem == column",
          "group": "constraint@4"
        },
        {
          "command": "database.newCheck",
          "when": "viewItem == table || viewItem == column",
          "group": "constraint@5"
        },
        {
          "command": "database.newTable",
          "group": "object@1"
        },
        {
          "command": "database.newMaterializedView",
          "group": "object@2"
        },
        {
          "command": "database.newView",
          "group": "object@3"
        },
        {
          "command": "database.newSequence",
          "group": "object@4"
        },
        {
          "command": "database.newSchema",
          "group": "object@5"
        },
        {
          "command": "database.addConnection",
          "group": "datasource@1"
        }
      ],
      "database.copyPaste": [
        {
          "command": "database.copyName",
          "group": "copy@1"
        },
        {
          "command": "database.copyQualifiedName",
          "group": "copy@2"
        },
        {
          "command": "database.showObjectDdl",
          "when": "viewItem == table || viewItem == schema",
          "group": "copy@3"
        }
      ],
      "database.sqlScripts": [
        {
          "command": "database.showObjectDdl",
          "when": "viewItem == table",
          "group": "ddl@1"
        },
        {
          "command": "database.generateSelect",
          "group": "generate@1"
        },
        {
          "command": "database.generateInsert",
          "when": "viewItem == table",
          "group": "generate@2"
        },
        {
          "command": "database.generateUpdate",
          "when": "viewItem == table",
          "group": "generate@3"
        },
        {
          "command": "database.generateDelete",
          "when": "viewItem == table",
          "group": "generate@4"
        }
      ],
      "database.objectActions": [
        {
          "command": "database.openTableData",
          "when": "viewItem == table",
          "group": "data@1"
        },
        {
          "command": "database.analyzeTablePerformance",
          "when": "viewItem == table",
          "group": "data@2"
        },
        {
          "command": "database.profileTableData",
          "when": "viewItem == table",
          "group": "data@3"
        },
        {
          "command": "database.generateTableMaintenanceSql",
          "when": "viewItem == table",
          "group": "data@4"
        },
        {
          "command": "database.importTableData",
          "when": "viewItem == table",
          "group": "data@5"
        },
        {
          "command": "database.modifyTable",
          "when": "viewItem == table",
          "group": "data@6"
        },
        {
          "command": "database.renameObject",
          "group": "change@1"
        },
        {
          "command": "database.dropObject",
          "group": "change@99"
        }
      ],
      "database.tools": [
        {
          "command": "database.quickDocumentation",
          "group": "inspect@1"
        },
        {
          "command": "database.refreshExplorer",
          "group": "inspect@2"
        },
        {
          "command": "database.showSqlMetadataStatus",
          "group": "inspect@3"
        },
        {
          "command": "database.sessionMonitor",
          "group": "inspect@4"
        },
        {
          "command": "database.copyTableToConnection",
          "group": "inspect@5"
        },
        {
          "command": "database.compareSchemas",
          "group": "inspect@6"
        },
        {
          "command": "database.showErDiagram",
          "group": "inspect@7"
        },
        {
          "command": "database.showQueryHistory",
          "group": "history@1"
        },
        {
          "command": "database.findPastQuery",
          "group": "history@2"
        },
        {
          "command": "database.backfillQueryMemorySummaries",
          "group": "history@3"
        },
        {
          "command": "database.aiFixSql",
          "group": "ai@1"
        },
        {
          "command": "database.aiExplainSql",
          "group": "ai@2"
        }
      ],
      "editor/context": [
        {
          "command": "database.setSqlFileConnection",
          "when": "editorLangId == sql",
          "group": "navigation@0"
        },
        {
          "command": "database.executeFile",
          "when": "editorLangId == sql",
          "group": "navigation@1"
        },
        {
          "command": "database.cancelCurrentQuery",
          "when": "editorLangId == sql && database.queryRunning",
          "group": "navigation@2"
        },
        {
          "command": "database.findPastQuery",
          "when": "editorLangId == sql",
          "group": "history@1"
        },
        {
          "command": "database.showSqlMetadataStatus",
          "when": "editorLangId == sql",
          "group": "inspect@1"
        },
        {
          "command": "database.insertQuerySnippet",
          "when": "editorLangId == sql",
          "group": "inspect@2"
        },
        {
          "command": "database.visualExplainSql",
          "when": "editorLangId == sql",
          "group": "inspect@3"
        },
        {
          "command": "database.visualExplainAnalyzeSql",
          "when": "editorLangId == sql",
          "group": "inspect@4"
        },
        {
          "command": "database.aiFixSql",
          "when": "editorLangId == sql",
          "group": "ai@1"
        },
        {
          "command": "database.aiExplainSql",
          "when": "editorLangId == sql",
          "group": "ai@2"
        }
      ],
      "editor/title": [
        {
          "command": "database.executeFile",
          "when": "editorLangId == sql",
          "group": "navigation@1"
        },
        {
          "command": "database.cancelCurrentQuery",
          "when": "editorLangId == sql && database.queryRunning",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "database.setSqlFileConnection",
          "when": "editorLangId == sql",
          "group": "navigation@0"
        },
        {
          "command": "database.executeFile",
          "when": "editorLangId == sql",
          "group": "navigation@1"
        },
        {
          "command": "database.cancelCurrentQuery",
          "when": "editorLangId == sql && database.queryRunning",
          "group": "navigation@2"
        },
        {
          "command": "database.findPastQuery",
          "when": "editorLangId == sql",
          "group": "history@1"
        },
        {
          "command": "database.showSqlMetadataStatus",
          "when": "editorLangId == sql",
          "group": "inspect@1"
        },
        {
          "command": "database.insertQuerySnippet",
          "when": "editorLangId == sql",
          "group": "inspect@2"
        },
        {
          "command": "database.visualExplainSql",
          "when": "editorLangId == sql",
          "group": "inspect@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "database.executeFile",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == sql"
      },
      {
        "command": "database.focusResults",
        "key": "ctrl+alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "database.focusExplorer",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "database.openSqlConsole",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q"
      },
      {
        "command": "database.openQueryFile",
        "key": "ctrl+alt+shift+q",
        "mac": "cmd+alt+shift+q"
      },
      {
        "command": "database.findPastQuery",
        "key": "ctrl+alt+h",
        "mac": "cmd+alt+h"
      }
    ],
    "configuration": {
      "title": "Database",
      "properties": {
        "database.defaultMaxRows": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Maximum rows fetched for select/with queries by default. Set to 0 to fetch all rows."
        },
        "database.resultTabs.reuseUnpinned": {
          "type": "boolean",
          "default": true,
          "description": "Deprecated. Result tabs now reuse the active unpinned tab automatically and only open a new tab when the active tab is pinned."
        },
        "database.resultTabs.persistPinned": {
          "type": "boolean",
          "default": true
        },
        "database.query.timeoutMs": {
          "type": "number",
          "default": 300000
        },
        "database.grid.density": {
          "type": "string",
          "enum": [
            "compact",
            "comfortable"
          ],
          "default": "compact"
        },
        "database.grid.enableVirtualization": {
          "type": "boolean",
          "default": true
        },
        "database.safety.confirmDestructiveQueries": {
          "type": "boolean",
          "default": true
        },
        "database.safety.confirmDestructiveQueriesOnAllConnections": {
          "type": "boolean",
          "default": false,
          "description": "Show destructive SQL confirmation on all connections, not only connections marked production."
        },
        "database.history.maxItems": {
          "type": "number",
          "default": 1000
        },
        "database.queryMemory.maxItems": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "description": "Maximum local query memory records retained for semantic-style search."
        },
        "database.dataProfile.sampleRows": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "description": "Maximum table rows sampled for one-click data profiling."
        },
        "database.ai.provider": {
          "type": "string",
          "enum": [
            "vscodeLanguageModel",
            "copilot",
            "openAiCompatible"
          ],
          "default": "vscodeLanguageModel",
          "description": "AI provider used by SQL AI features."
        },
        "database.ai.vscodeLanguageModel.vendor": {
          "type": "string",
          "default": "copilot",
          "description": "Preferred VS Code language model vendor. Leave empty to use the first available registered language model."
        },
        "database.ai.copilot.vendor": {
          "type": "string",
          "default": "copilot",
          "markdownDeprecationMessage": "Use `database.ai.vscodeLanguageModel.vendor` instead.",
          "description": "Legacy VS Code Language Model vendor selector used by SQL AI features."
        },
        "database.ai.openAiCompatible.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for an OpenAI-compatible Chat Completions API, for example a self-hosted gateway ending in /v1."
        },
        "database.ai.openAiCompatible.model": {
          "type": "string",
          "default": "",
          "description": "Model name sent to the OpenAI-compatible Chat Completions API."
        },
        "database.ai.openAiCompatible.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the OpenAI-compatible provider. This is stored in VS Code settings; use `database.ai.openAiCompatible.apiKeyEnvVar` if you prefer environment-based secrets."
        },
        "database.ai.openAiCompatible.apiKeyEnvVar": {
          "type": "string",
          "default": "DATABASE_AI_API_KEY",
          "description": "Environment variable read for the OpenAI-compatible API key when database.ai.openAiCompatible.apiKey is empty."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --external:pg --external:pg/* --external:pg-native --external:mysql2 --external:mysql2/* --external:sql-formatter --external:xlsx --sourcemap --outfile=dist/extension.js",
    "bundle:runtimes": "esbuild src/runtime/pgRuntime.ts src/runtime/mysqlRuntime.ts src/runtime/sqlFormatterRuntime.ts src/runtime/xlsxRuntime.ts --bundle --platform=node --format=cjs --target=node20 --external:pg-native --sourcemap --outdir=dist/runtime",
    "bundle:webview": "vite build --config vite.config.ts",
    "copy:codicons": "node -e \"const fs=require('fs');fs.mkdirSync('media/codicons',{recursive:true});for(const f of ['codicon.css','codicon.ttf'])fs.copyFileSync('node_modules/@vscode/codicons/dist/'+f,'media/codicons/'+f);\"",
    "build": "npm run copy:codicons && npm run compile && npm run bundle:extension && npm run bundle:runtimes && npm run bundle:webview",
    "lint": "tsc -p ./ --noEmit",
    "test": "vitest run",
    "compile:e2e": "tsc -p e2e",
    "test:e2e": "npm run compile && npm run compile:e2e && vscode-test",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@vitejs/plugin-react": "^4.3.4",
    "mysql2": "^3.22.5",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sql-formatter": "^15.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.9",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.14",
    "vitest": "^1.6.1"
  }
